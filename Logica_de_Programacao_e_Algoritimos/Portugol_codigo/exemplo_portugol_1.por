programa {
  funcao inicio() {
    inteiro nota1, nota2, nota3, nota4
    real media

    escreva("nota1:")
    leia(nota1)

    escreva("nota2:")
    leia(nota2)

    escreva("nota3:")
    leia(nota3)

    escreva("nota4:")
    leia(nota4)

    media=(nota1+nota2+nota3+nota4)/4
    escreva("Média:",media)
  }
}
